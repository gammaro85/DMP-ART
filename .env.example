# DMP-ART Environment Configuration
# Skopiuj ten plik do .env i uzupełnij wartości

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=change-this-to-a-random-secret-key

# Server Configuration (for production mode)
GUNICORN_WORKERS=4
GUNICORN_HOST=0.0.0.0
GUNICORN_PORT=5000

# Optional: AI Module Configuration (if using AI features)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: File Upload Configuration
# MAX_UPLOAD_SIZE_MB=16
