   --subsection-title-color: #3e6a4c;
   --shadow-light: 0 1px 3px rgba(24, 48, 82, 0.12);
@@ -57,7 +57,7 @@
   --border-light: #c0cedf;
   --border-medium: #a6b9d0;
   --border-dark: #7e95b0;
-  --status-info: rgba(50, 112, 224, 0.10);
+  --status-info: rgba(45, 131, 200, 0.10);
   --status-warning: rgba(229, 173, 26, 0.10);
   --status-success: rgba(34, 145, 59, 0.10);
