-  --primary-color: #3270e0;
-  --primary-hover: #1f54cc;
-  --secondary-color: #5090e8;
-  --accent-color: #1f54cc;
-  --navy: #3270e0;
+  --primary-color: #2d83c8;
+  --primary-hover: #1c66b3;
+  --secondary-color: #4d9ad6;
+  --accent-color: #1c66b3;
+  --navy: #2d83c8;
   --light-color: #e2e7f0;
   --dark-color: #143546;
   --error-color: #c92e3e;
@@ -32,7 +32,7 @@
