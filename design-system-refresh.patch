-  --primary-hover: #2563eb;
+  --primary-hover: #2381cc;
   --yellow-highlight: #1c3a5a;
   --bg-alt: #4b5563;
   --error-hover: #f06b6b;
   --success-hover: #22c55e;
   --warning-hover: #fbbf24;
   --text-inverse: #ffffff;
-  --primary-rgb: 59, 130, 246;
-  --status-info: rgba(59, 130, 246, 0.15);
+  --primary-rgb: 56, 151, 220;
+  --status-info: rgba(56, 151, 220, 0.15);
   --status-warning: rgba(251, 191, 36, 0.15);
   --status-success: rgba(74, 222, 128, 0.15);
   --status-error: rgba(248, 113, 113, 0.15)
==============================================================

Branch + apply:

    git checkout -b design-system-refresh
    git apply design-system-refresh.patch
    # copy the gold logo from this project's assets/ folder:
    cp /path/to/logo-main-dark-gold.png \
       static/images/dmp-art-logo-main-dark-gold.png
    # then wire it up in the templates that load the dark logo
    git add -A
    git commit -m "Design system: cyan-shifted palette + gold dark logo"
    git push -u origin design-system-refresh
